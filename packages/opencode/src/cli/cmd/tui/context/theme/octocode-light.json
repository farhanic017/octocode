{
  "$schema": "https://octocode.ai/theme.json",
  "defs": {
    "lightBg": "#f8f8f8",
    "lightPanel": "#ebebeb",
    "lightElement": "#d8d8d8",
    "lightBorder": "#c0c0c0",
    "lightBorderActive": "#b0b0b0",
    "lightText": "#1a1a1a",
    "lightMuted": "#707070",
    "lightDim": "#9a9a9a",
    "lightPink": "#c47095",
    "lightPurple": "#9b52d8",
    "lightIcon": "#d0d0d0",
    "lightRed": "#d1383d",
    "lightOrange": "#d48a2a",
    "lightGreen": "#3d9a57",
    "lightCyan": "#318795",
    "lightYellow": "#b0851f"
  },
  "theme": {
    "primary": "lightPink",
    "secondary": "lightPurple",
    "accent": "lightPurple",
    "error": "lightRed",
    "warning": "lightOrange",
    "success": "lightGreen",
    "info": "lightCyan",
    "text": "lightText",
    "textMuted": "lightMuted",
    "background": "lightBg",
    "backgroundPanel": "lightPanel",
    "backgroundElement": "lightElement",
    "border": "lightBorder",
    "borderActive": "lightBorderActive",
    "borderSubtle": "lightDim",
    "diffAdded": "#2d8a56",
    "diffRemoved": "#c53b53",
    "diffContext": "#5a6a9a",
    "diffHunkHeader": "#5a6a9a",
    "diffHighlightAdded": "#3daa66",
    "diffHighlightRemoved": "#d14a5a",
    "diffAddedBg": "#d5eed5",
    "diffRemovedBg": "#f7d8db",
    "diffContextBg": "lightPanel",
    "diffLineNumber": "#999999",
    "diffAddedLineNumberBg": "#c5d5c5",
    "diffRemovedLineNumberBg": "#e7c8cb",
    "markdownText": "lightText",
    "markdownHeading": "lightPink",
    "markdownLink": "lightPurple",
    "markdownLinkText": "lightCyan",
    "markdownCode": "lightGreen",
    "markdownBlockQuote": "lightYellow",
    "markdownEmph": "lightYellow",
    "markdownStrong": "lightPink",
    "markdownHorizontalRule": "lightDim",
    "markdownListItem": "lightPink",
    "markdownListEnumeration": "lightCyan",
    "markdownImage": "lightPink",
    "markdownImageText": "lightCyan",
    "markdownCodeBlock": "lightText",
    "syntaxComment": "lightDim",
    "syntaxKeyword": "lightPurple",
    "syntaxFunction": "lightPink",
    "syntaxVariable": "lightRed",
    "syntaxString": "lightGreen",
    "syntaxNumber": "lightOrange",
    "syntaxType": "lightYellow",
    "syntaxOperator": "lightCyan",
    "syntaxPunctuation": "lightMuted"
  }
}
